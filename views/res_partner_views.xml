<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_bugfix_sales" model="ir.ui.view">
        <field name="name">res.partner.form.bugfix_sales</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Move the Reference (res.partner.ref) field out of the
                 Sales & Purchase → Misc group and hoist it to the
                 very top of the header — ABOVE the Company/Contact
                 name H1 — rendered in its own <h1> so the styling
                 matches the name (big + bold). company_registry and
                 company_id stay where they were. -->
            <xpath expr="//group[@name='misc']/field[@name='ref']"
                   position="replace"/>

            <xpath expr="//div[hasclass('oe_title')]//h1"
                   position="before">
                <h1>
                    <field name="ref"
                           class="text-break"
                           placeholder="Reference"/>
                </h1>
            </xpath>

        </field>
    </record>

</odoo>
