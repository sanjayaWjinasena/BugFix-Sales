<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_bugfix_sales" model="ir.ui.view">
        <field name="name">res.partner.form.bugfix_sales</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Move the Reference (res.partner.ref) field out of the
                 Sales & Purchase → Misc group and up to the header,
                 right below the H1 name. Company Registry and
                 company_id stay where they were. -->
            <xpath expr="//group[@name='misc']/field[@name='ref']"
                   position="replace"/>

            <xpath expr="//div[hasclass('oe_title')]//h1"
                   position="after">
                <field name="ref"
                       string="Reference"
                       placeholder="e.g. CUST-00123"/>
            </xpath>

        </field>
    </record>

</odoo>
