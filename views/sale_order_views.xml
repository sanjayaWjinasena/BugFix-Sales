<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_bugfix_sales" model="ir.ui.view">
        <field name="name">sale.order.form.bugfix_sales</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Add the two Many2one selectors next to validity_date in the
                 quotation header (right column). -->
            <xpath expr="//field[@name='validity_date']" position="after">
                <field name="bugfix_sales_intro_id"
                       options="{'no_create': True, 'no_create_edit': True}"/>
                <field name="bugfix_sales_conclusion_id"
                       options="{'no_create': True, 'no_create_edit': True}"/>
            </xpath>

            <!-- Credit-limit gate on the Confirm button.
                 Mirrors the visibility of the studio-installed
                 "Request Credit Limit Approval" button: while the SO
                 has tripped the credit limit (x_studio_over_credit)
                 and the approval has not yet been granted
                 (x_studio_credit_limit_approved), the Confirm button
                 is hidden so the sales user cannot confirm the order
                 until approval is completed.

                 There are two Confirm buttons on sale.view_order_form
                 — the primary (state=='sent') carries id="action_confirm",
                 the secondary (state=='draft') does not. Each is
                 patched independently because position="attributes"
                 in Odoo view inheritance only patches the first match
                 of the xpath. `separator=" or "` appends the new
                 predicate to the existing state check with OR.

                 The two x_studio_ fields must be declared in this
                 view's arch (as invisible fields) because Odoo view
                 validation requires every field referenced in a
                 modifier expression to be present in the same view.
                 Studio-generated views bypass this via noupdate=1,
                 hand-written module views do not. -->
            <xpath expr="//header" position="inside">
                <field name="x_studio_over_credit" invisible="1"/>
                <field name="x_studio_credit_limit_approved" invisible="1"/>
            </xpath>
            <xpath expr="//button[@name='action_confirm' and @id='action_confirm']"
                   position="attributes">
                <attribute name="invisible"
                           add="x_studio_over_credit == True and x_studio_credit_limit_approved != True"
                           separator=" or "/>
            </xpath>
            <xpath expr="//button[@name='action_confirm' and not(@id)]"
                   position="attributes">
                <attribute name="invisible"
                           add="x_studio_over_credit == True and x_studio_credit_limit_approved != True"
                           separator=" or "/>
            </xpath>

            <!-- Add a new notebook page holding the editable text bodies.
                 Placed inside the existing notebook after Order Lines. -->
            <xpath expr="//notebook" position="inside">
                <page string="Document Text"
                      name="bugfix_sales_document_text">
                    <group string="Introduction (printed above order lines)">
                        <field name="bugfix_sales_intro_text"
                               nolabel="1"
                               placeholder="Select a Document Introduction on the header — the description will appear here and can be edited per-quote."/>
                    </group>
                    <group string="Conclusion (printed after totals)">
                        <field name="bugfix_sales_conclusion_text"
                               nolabel="1"
                               placeholder="Select a Document Conclusion on the header — the description will appear here and can be edited per-quote."/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
