<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Register <function model="..." name="..."/> calls here as new
         bug-fix seed/patch functions are added.  Each call runs on
         every install and upgrade of this module. -->

    <!-- Ensure every active res.company carries a row on the Studio-
         manual x_minimum_sales_margin catalogue. The three consumers
         (compute on account.payment.x_studio_payment_validation, and
         server actions RR - Validate Payment % / SLS - Create
         Customer Payment) rely on a per-company config existing, but
         Studio automation 146 blocks ORM create() when any active
         row exists — so the seed uses raw SQL to bypass the guard
         and only inserts rows for companies that don't already have
         one. Idempotent. -->
    <function model="bugfix_sales.minimum_sales_margin.seed"
              name="_seed_minimum_sales_margin_per_company"/>

    <!-- v21 migration: copy the four config values from each
         x_minimum_sales_margin row into ir.config_parameter under
         per-company keys (see res.company._BUGFIX_SALES_CONFIG for
         the key format). Runs AFTER the seed above so freshly-added
         companies inherit default values before migration; idempotent
         (only writes keys that don't already exist), so Settings
         edits done between upgrades survive future runs. -->
    <function model="bugfix_sales.minimum_sales_margin.seed"
              name="_migrate_to_config_parameter"/>

    <!-- Hide the Studio-generated 'Sales Configurations' list/form
         menus since v17 (this module) moved the four config values
         into Settings → Sales. Editing a database-record list is the
         wrong UX for what is really a per-company configuration —
         users could accidentally create duplicate rows (hitting
         automation 146's cross-company guard) or edit rows for a
         company they're not currently in. Menus are deactivated, not
         deleted: model, actions, views, and rows all stay intact for
         debugging. Idempotent. -->
    <function model="bugfix_sales.minimum_sales_margin.seed"
              name="_hide_minimum_sales_margin_menus"/>

    <!-- Sweep orphan studio_customization pins on ir.ui.menu whose
         target menu record no longer exists. Ran into two such
         orphans after v18 (deactivation cascade missed the pin
         cleanup). Narrow-scoped, idempotent. -->
    <function model="bugfix_sales.minimum_sales_margin.seed"
              name="_cleanup_orphan_studio_menu_pins"/>

    <!-- Attach the Document Introduction / Conclusion QWeb overlay to
         the Studio 'C01 Sales Quotation' report. Uses the report's
         human name as the stable lookup key (not the per-database
         Studio UUID), so the module installs cleanly on any
         instance regardless of Studio state. If the C01 report isn't
         present on this database, the method skips silently and the
         module still installs. Idempotent. -->
    <function model="bugfix_sales.minimum_sales_margin.seed"
              name="_attach_c01_intro_conclusion_view"/>
</odoo>
