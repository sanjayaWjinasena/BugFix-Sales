<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit the Studio-authored "C01 Sales Quotation" QWeb template
         to render the Document Introduction above the items table and
         the Document Conclusion above the hardcoded terms footer.

         Target template: studio_customization.c01_sales_quotation document
         view id 9072 on clear-db, xml_id
         studio_customization.studio_customization_904d473c-5727-402b-8090-5615a762dc13
         (name in Print menu: "C01 Sales Quotation").

         Anchor choice notes for THIS template's arch:

           //table[hasclass('table-sm')][1]
                                   — the items table (first `.table-sm`
                                     in the arch; the totals table is
                                     the second). Placing intro
                                     position="before" puts it
                                     immediately after the customer
                                     info row (which is the only
                                     element between the header and
                                     the items table), matching the
                                     reference PDF's "Notes:" position
                                     below the "VAT Registered:" line.

           //span[contains(@style, 'white-space: pre-line')]
                                   — the hardcoded terms span
                                     (Availability / Terms of Payment /
                                     Guarantee / Taxes). Placing
                                     conclusion before it puts our
                                     dynamic conclusion above the
                                     hardcoded terms, ahead of the
                                     "Please draw cheques" footer.

         Behaviour: both blocks render only when the corresponding text
         field on the sale.order is populated (t-if guard). If the
         salesperson doesn't select a Document Introduction / Conclusion
         on the quote, the printed layout is unchanged from before.

         The hardcoded terms span (Availability 2-3 weeks / Terms 60%
         etc) is deliberately left in place — the user can either remove
         it in Studio or keep it as a fallback below the dynamic
         conclusion. Not touching Studio arch from here. -->
    <template id="bugfix_sales_c01_quotation_intro_conclusion"
              inherit_id="studio_customization.studio_customization_904d473c-5727-402b-8090-5615a762dc13">

        <!-- INTRODUCTION: immediately before the items table, which
             puts it right after the customer info row (below the
             "VAT Registered:" line). Rendered as a "Notes:" block
             matching the reference PDF layout. -->
        <xpath expr="//table[hasclass('table-sm')][1]" position="before">
            <div t-if="doc.bugfix_sales_intro_text"
                 class="mt-3 mb-3"
                 style="white-space: pre-wrap; font-size: 10pt;">
                <strong>Notes:</strong>
                <br/>
                <t t-out="doc.bugfix_sales_intro_text"/>
            </div>
        </xpath>

        <!-- CONCLUSION: immediately after the totals table (the
             second `.table-sm` in the arch), before the hardcoded
             terms span. -->
        <xpath expr="//table[hasclass('table-sm')][2]" position="after">
            <div t-if="doc.bugfix_sales_conclusion_text"
                 class="mt-3 mb-3"
                 style="white-space: pre-wrap; font-size: 10pt;">
                <t t-out="doc.bugfix_sales_conclusion_text"/>
            </div>
        </xpath>

    </template>

</odoo>
